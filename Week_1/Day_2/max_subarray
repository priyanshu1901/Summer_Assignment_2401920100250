/ Question 3 (Maximum Subarray)

class Solution {
    public int maxSubArray(int[] arr) {
        int mxsum  = arr[0];
        int n = arr.length;
        int sum = 0;
        for(int i=0;i<n;i++){
            sum +=arr[i];
            mxsum = Math.max(sum,mxsum);
            if(sum<0) sum = 0;
        }
        return mxsum;
    }
}