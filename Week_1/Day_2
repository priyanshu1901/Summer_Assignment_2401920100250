// Question 2 (contains duplicate)

class Solution {
    public boolean containsDuplicate(int[] arr) {
        HashSet<Integer> set = new HashSet<>();
        for(int ele: arr){
            if(set.contains(ele)) return true;
            else set.add(ele);
        }
        return false;
    }
}

// Question 3 (Maximum Avg Subarray I )

class Solution {
    public double findMaxAverage(int[] arr, int k) {
        int sum =0;
        int n = arr.length;
        for(int i=0;i<k;i++){
            sum += arr[i];
        }
        int mxsum = sum;
        for(int i=k;i<n;i++){
        sum += arr[i];
        sum -= arr[i-k];
        if(mxsum < sum) mxsum = sum; 
        }
        double avg = (double) mxsum / k;
        return avg;
    }
}    