class Solution {
    public int maxArea(int[] high) {
        int n = high.length;
        int l = 0;
        int r = n-1;
        int mx = 0;
        while(l<r){
            int wid = r -l;
            int area = Math.min(high[l],high[r]) * wid;
            mx = Math.max(mx,area);

            if(high[l]<high[r]) l++;
            else r--;
        }
        return mx;
    }
}