class Solution {
    public ListNode reverseList(ListNode head) {
        if(head == null || head.next == null) return head;
        ListNode prev = null;
        ListNode current = head;
        ListNode Next = null;
        while(current != null) {
            Next = current.next;
            current.next = prev;
            prev = current;
            current = Next;
        }
        return prev;
    }
}